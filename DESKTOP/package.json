    "release:ui-conversation-queue-plan-smoke": "node scripts/release-ui-conversation-queue-plan-smoke.cjs",
    "release:ui-fast-conversation-switch-smoke": "node scripts/release-ui-fast-conversation-switch-smoke.cjs",
    "release:ui-workspace-conversation-isolation-smoke": "node scripts/release-ui-workspace-conversation-isolation-smoke.cjs",
    "release:ui-multi-window-shared-backend-smoke": "node scripts/release-ui-multi-window-shared-backend-smoke.cjs",
    "release:linux-gui-smoke": "node scripts/release-linux-gui-smoke.cjs",
    "release:linux-appimage-smoke": "node scripts/release-linux-appimage-smoke.cjs",
    "release:linux-unpacked-zip-smoke": "node scripts/release-linux-unpacked-zip-smoke.cjs",
    "release:linux-deb-smoke": "node scripts/release-linux-deb-smoke.cjs",
