{
  "name": "newmark-agent",
  "productName": "Newmark Agent",
  "version": "0.0.5",
  "description": "Newmark Agent — Portable AI coding agent with rich GUI and CLI (TypeScript)",
  "homepage": "https://github.com/positer/Newmark-Agent",
  "author": {
    "name": "Newmark AI",
    "email": "support@newmark.ai"
  },
  "main": "dist/main.js",
  "scripts": {
    "clean": "tsc --build --clean && node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "build": "tsc && node scripts/build-ui-icons.cjs",
    "build:clean": "npm run clean && npm run build",
    "dev": "npm run build && node dist/launcher.js --server",
    "dev:cli": "npm run build && node dist/launcher.js --cli",
    "start": "electron .",
    "start:dev": "npm run build && electron .",
    "start:cli": "node dist/launcher.js --cli",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint src",
    "test": "npm run build && node dist/tests/verify.js",
    "dist:win": "npm run build:clean && electron-builder --win",
    "release": "npm run build:clean && node scripts/dist-portable.cjs",
    "dist:portable": "npm run build:clean && node scripts/dist-portable.cjs",
    "release:cli-smoke": "node scripts/release-cli-smoke.cjs",
    "release:111-cli-smoke": "node scripts/release-111-cli-smoke.cjs",
    "release:111-ui-smoke": "node scripts/release-111-ui-smoke.cjs",
    "release:computer-use-vision-smoke": "node scripts/release-computer-use-vision-smoke.cjs",
    "release:real-ui-copilot-computeruse-smoke": "node scripts/release-real-ui-copilot-computeruse-smoke.cjs",
    "release:cli-ui-conversation-sync-smoke": "node scripts/release-cli-ui-conversation-sync-smoke.cjs",
    "release:ui-smoke": "node scripts/release-ui-smoke.cjs",
    "release:ui-agent-smoke": "node scripts/release-ui-agent-smoke.cjs",
    "release:ui-acceptance-smoke": "node scripts/release-ui-acceptance-smoke.cjs",
    "release:ui-integration-smoke": "node scripts/release-ui-integration-smoke.cjs",
    "release:ui-external-workspace-smoke": "node scripts/release-ui-external-workspace-smoke.cjs",
    "release:ui-option-feedback-smoke": "node scripts/release-ui-option-feedback-smoke.cjs",
    "release:ui-model-settings-smoke": "node scripts/release-ui-model-settings-smoke.cjs",
    "release:ui-model-auto-context-smoke": "node scripts/release-ui-model-auto-context-smoke.cjs",
    "release:ui-gemma-removal-smoke": "node scripts/release-ui-gemma-removal-smoke.cjs",
    "release:ui-icon-smoke": "node scripts/release-ui-icon-smoke.cjs",
    "release:ui-flow-subagent-smoke": "node scripts/release-ui-flow-subagent-smoke.cjs",
    "release:ui-media-md-smoke": "node scripts/release-ui-media-md-smoke.cjs",
    "release:ui-native-editor-smoke": "node scripts/release-ui-native-editor-smoke.cjs",
    "release:real-editor-copilot-smoke": "node scripts/release-real-editor-copilot-smoke.cjs",
    "release:ui-skills-smoke": "node scripts/release-ui-skills-smoke.cjs",
    "release:ui-memory-lab-smoke": "node scripts/release-ui-memory-lab-smoke.cjs",
    "release:ui-conversation-queue-plan-smoke": "node scripts/release-ui-conversation-queue-plan-smoke.cjs",
    "release:ui-fast-conversation-switch-smoke": "node scripts/release-ui-fast-conversation-switch-smoke.cjs",
    "release:ui-workspace-conversation-isolation-smoke": "node scripts/release-ui-workspace-conversation-isolation-smoke.cjs",
    "release:ui-multi-window-shared-backend-smoke": "node scripts/release-ui-multi-window-shared-backend-smoke.cjs",
    "release:linux-gui-smoke": "node scripts/release-linux-gui-smoke.cjs",
    "release:linux-real-provider-smoke": "node scripts/release-linux-real-provider-smoke.cjs",
    "release:ui-startup-recovery-smoke": "node scripts/release-ui-startup-recovery-smoke.cjs",
    "release:ui-tray-lifecycle-smoke": "node scripts/release-ui-tray-lifecycle-smoke.cjs",
    "release:ui-goal-continuation-smoke": "node scripts/release-ui-goal-continuation-smoke.cjs",
    "release:ui-workspace-lifecycle-smoke": "node scripts/release-ui-workspace-lifecycle-smoke.cjs",
    "release:real-claude-env-preview-smoke": "node scripts/release-real-claude-env-preview-smoke.cjs",
    "release:real-provider-smoke": "node scripts/release-real-provider-smoke.cjs",
    "release:real-apinebula-memory-switch-smoke": "node scripts/release-real-apinebula-memory-switch-smoke.cjs",
    "release:real-provider-stress": "node scripts/release-real-provider-stress.cjs",
    "dist:win:installer": "npm run dist:windows-release",
    "dist:linux": "node scripts/dist-linux.cjs",
    "dist:linux:native": "npm run build:clean && electron-builder --linux",
    "dist:mac": "npm run build:clean && electron-builder --mac",
    "dist:windows-release": "npm run build:clean && node scripts/dist-portable.cjs"
  },
  "build": {
    "appId": "ai.newmark.agent",
    "productName": "Newmark Agent",
    "executableName": "Newmark Agent",
    "copyright": "Copyright © 2025 Newmark AI",
    "directories": {
      "output": "../release",
      "buildResources": "assets"
    },
    "files": [
      "dist/**/*",
      "assets/**/*",
      "config.example.json",
      "package.json"
    ],
    "extraFiles": [
      {
        "from": "../LICENSE",
        "to": "LICENSE"
      },
      {
        "from": "../THIRD_PARTY_NOTICES.md",
        "to": "THIRD_PARTY_NOTICES.md"
      },
      {
        "from": "Flow",
        "to": "Flow",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "icon": "assets/icon.ico",
      "sign": false,
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "msi",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "Newmark-Agent-${version}-${arch}.${ext}"
    },
    "linux": {
      "icon": "assets/app-icon-dark.png",
      "maintainer": "Newmark AI <support@newmark.ai>",
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Development",
      "artifactName": "Newmark-Agent-${version}-${arch}.${ext}"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "category": "public.app-category.developer-tools",
      "artifactName": "Newmark-Agent-${version}-${arch}.${ext}"
    },
    "msi": {
      "oneClick": false,
      "perMachine": true,
      "warningsAsErrors": false,
      "artifactName": "Newmark-Agent-${version}-${arch}.${ext}"
    }
  },
  "dependencies": {
    "@mozilla/readability": "^0.6.0",
    "cross-fetch": "^4.0.0",
    "glob": "^7.2.3",
    "https-proxy-agent": "^9.1.0",
    "jsdom": "^29.1.1",
    "lucide-static": "^1.21.0",
    "resedit": "^1.7.2",
    "typebox": "^1.1.38"
  },
  "devDependencies": {
    "@types/jsdom": "^28.0.3",
    "@types/node": "^22.0.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "oxlint": "^0.9.0",
    "typescript": "^5.6.0"
  }
}
