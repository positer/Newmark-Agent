    "test:browser-use-electron": "npm run build && electron dist/tests/browserUseElectronVerify.js",
    "test:dev009": "npm run build && node dist/tests/dev009Verify.js && node dist/tests/runtimeIsolationVerify.js && node dist/tests/guideWorkRunVerify.js && node dist/tests/guideUiReconcileVerify.js && node dist/tests/queueAttachmentIsolationVerify.js && node dist/tests/workspaceMenuVerify.js && node dist/tests/userImagePersistenceVerify.js && node dist/tests/visualPreferencesVerify.js && node dist/tests/browserUseVerify.js && node dist/tests/toolProcessVerify.js && node dist/tests/startupPrewarmVerify.js && node dist/tests/pdfPreviewServerVerify.js && node dist/tests/editorLifecycleVerify.js && node dist/tests/computerUsePerformanceVerify.js && electron dist/tests/browserUseElectronVerify.js",
    "test:dev008": "npm run build && node dist/tests/dev008-subagent.js",
    "test:auto-router": "npm run build && node dist/tests/autoRouterVerify.js && node dist/tests/autoAgentIntegrationVerify.js && node dist/tests/autoRouteRatingVerify.js && node dist/tests/providerIdentityVerify.js",
    "test:model-validation": "npm run build && node dist/tests/modelValidationVerify.js && node dist/tests/modelValidationAgentIntegrationVerify.js",
    "test:runtime-pool": "npm run build && node dist/tests/runtimePoolCapacityVerify.js",
    "test:cli-tools": "npm run build && node dist/tests/cliToolContractVerify.js && node dist/tests/openAIHubAnthropicSmokeContractVerify.js && node dist/tests/cliComputerUseAccuracyVerify.js",
    "test:dev010": "npm run build && node dist/tests/normalChatRegressionVerify.js && node dist/tests/toolProvisioningVerify.js && node dist/tests/autoRouterVerify.js && node dist/tests/autoAgentIntegrationVerify.js && node dist/tests/autoRouteRatingVerify.js && node dist/tests/providerIdentityVerify.js && node dist/tests/modelValidationVerify.js && node dist/tests/modelValidationAgentIntegrationVerify.js && node dist/tests/runtimePoolCapacityVerify.js && node dist/tests/queueAttachmentIsolationVerify.js && node dist/tests/visualPreferencesVerify.js && node dist/tests/startupPrewarmVerify.js && node dist/tests/computerUsePerformanceVerify.js && node dist/tests/cliToolContractVerify.js && node dist/tests/openAIHubAnthropicSmokeContractVerify.js && node dist/tests/cliComputerUseAccuracyVerify.js",
    "test:computer-use-performance": "npm run build && node dist/tests/computerUsePerformanceVerify.js",
    "test:terminal-takeover": "npm run build && node dist/tests/terminalTakeoverVerify.js",
    "dist:win": "npm run build:clean && electron-builder --win",
    "release": "npm run build:clean && node scripts/dist-portable.cjs",
    "dist:portable": "npm run build:clean && node scripts/dist-portable.cjs",
    "release:cli-smoke": "node scripts/release-cli-smoke.cjs",
    "release:111-cli-smoke": "node scripts/release-111-cli-smoke.cjs",
    "release:111-ui-smoke": "node scripts/release-111-ui-smoke.cjs",
    "release:computer-use-vision-smoke": "node scripts/release-computer-use-vision-smoke.cjs",
    "release:real-ui-copilot-computeruse-smoke": "node scripts/release-real-ui-copilot-computeruse-smoke.cjs",
    "release:cli-ui-conversation-sync-smoke": "node scripts/release-cli-ui-conversation-sync-smoke.cjs",
    "release:ui-smoke": "node scripts/release-ui-smoke.cjs",
    "release:ui-agent-smoke": "node scripts/release-ui-agent-smoke.cjs",
    "release:ui-acceptance-smoke": "node scripts/release-ui-acceptance-smoke.cjs",
